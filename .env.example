# AlphaStrike Trading Bot - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Configuration (Ollama)
# =============================================================================

# Ollama API base URL
OLLAMA_BASE_URL=http://localhost:11434

# Model for LLM decisions and log explanations
# Options:
#   qwen2.5:3b      - Fast (1-3s), good for decisions/explanations
#   deepseek-r1:7b  - Slower (10-15s), better reasoning
OLLAMA_MODEL=qwen2.5:3b

# =============================================================================
# Exchange Selection
# =============================================================================
# Options: weex, hyperliquid, binance
EXCHANGE_NAME=weex

# =============================================================================
# WEEX Exchange API Credentials (CEX)
# =============================================================================
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_API_SECRET=your_api_secret_here
EXCHANGE_API_PASSPHRASE=your_passphrase_here

# WEEX API Endpoints
EXCHANGE_REST_URL=https://api.weex.com
EXCHANGE_WS_URL=wss://ws.weex.com

# =============================================================================
# Hyperliquid DEX Credentials
# =============================================================================
# For Hyperliquid, you need a wallet private key instead of API key/secret.
# The wallet address is derived from the private key if not specified.
#
# IMPORTANT: Never commit your private key to version control!
# Use a dedicated trading wallet with limited funds.
#
# To use Hyperliquid:
# 1. Set EXCHANGE_NAME=hyperliquid
# 2. Set EXCHANGE_WALLET_PRIVATE_KEY to your wallet's private key
# 3. Optionally set EXCHANGE_WALLET_ADDRESS (derived from key if empty)
#
# Example for Hyperliquid TESTNET paper trading:
# -----------------------------------------------
# EXCHANGE_NAME=hyperliquid
# EXCHANGE_WALLET_PRIVATE_KEY=0xabc123...your_64_char_hex_private_key
# EXCHANGE_WALLET_ADDRESS=0x64e830dd7aF93431C898eA9e4C375C6706bd0Fc5
#
# Get testnet USDC: https://app.hyperliquid-testnet.xyz/
# Run paper trader: python scripts/hyperliquid_testnet_trader.py --dry-run
#
# Example for Hyperliquid MAINNET (use with caution):
# ---------------------------------------------------
# EXCHANGE_NAME=hyperliquid
# EXCHANGE_WALLET_PRIVATE_KEY=0x...your_mainnet_private_key
# EXCHANGE_WALLET_ADDRESS=0x...your_mainnet_address

# Database
DATABASE_PATH=data/alphastrike.db

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Trading Mode
TRADING_ENABLED=true
PAPER_TRADING=false

# Risk Overrides (optional - defaults in config.py)
# MAX_LEVERAGE=20
# DAILY_DRAWDOWN_LIMIT=0.05
# TOTAL_DRAWDOWN_LIMIT=0.15
# MIN_BALANCE_THRESHOLD=9000.0

# =============================================================================
# Cloud Backup Configuration (Disaster Recovery)
# =============================================================================
# Multi-tier backup for resilience:
# - Hot tier (Upstash Redis): 1-5ms latency, locks, current state
# - Warm tier (Turso SQLite): 5-10ms latency, recent events
# - Cold tier (Supabase): 50-100ms latency, full audit trail

# Upstash Redis (Hot Tier) - https://upstash.com
# Free tier: 10K commands/day
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Turso SQLite (Warm Tier) - https://turso.tech
# Free tier: 9GB storage, 500M rows read/month
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Supabase (Cold Tier) - https://supabase.com
# Free tier: 500MB database, 1GB storage
SUPABASE_URL=
SUPABASE_KEY=

# Bot Instance ID (auto-generated if not set)
# Used for distributed locking to prevent split-brain
# INSTANCE_ID=alphastrike-prod-1
