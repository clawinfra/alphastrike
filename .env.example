# AlphaStrike Trading Bot - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Configuration (Ollama)
# =============================================================================

# Ollama API base URL
OLLAMA_BASE_URL=http://localhost:11434

# Model for LLM decisions and log explanations
# Options:
#   qwen2.5:3b      - Fast (1-3s), good for decisions/explanations
#   deepseek-r1:7b  - Slower (10-15s), better reasoning
OLLAMA_MODEL=qwen2.5:3b

# =============================================================================
# Exchange Selection
# =============================================================================
# Options: weex, hyperliquid, binance
EXCHANGE_NAME=hyperliquid

# =============================================================================
# WEEX Exchange API Credentials (CEX)
# =============================================================================
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_API_SECRET=your_api_secret_here
EXCHANGE_API_PASSPHRASE=your_passphrase_here

# WEEX API Endpoints
EXCHANGE_REST_URL=https://api.weex.com
EXCHANGE_WS_URL=wss://ws.weex.com

# =============================================================================
# Hyperliquid DEX Credentials
# =============================================================================
# For Hyperliquid, you need a wallet private key instead of API key/secret.
# The wallet address is derived from the private key if not specified.
#
# IMPORTANT: Never commit your private key to version control!
# Use a dedicated trading wallet with limited funds.
#
# To use Hyperliquid:
# 1. Set EXCHANGE_NAME=hyperliquid
# 2. Set EXCHANGE_WALLET_PRIVATE_KEY to your wallet's private key
# 3. Optionally set EXCHANGE_WALLET_ADDRESS (derived from key if empty)
#
# Example for Hyperliquid TESTNET paper trading:
# -----------------------------------------------
# EXCHANGE_NAME=hyperliquid
# EXCHANGE_WALLET_PRIVATE_KEY=0xabc123...your_64_char_hex_private_key
# EXCHANGE_WALLET_ADDRESS=0x64e830dd7aF93431C898eA9e4C375C6706bd0Fc5
#
# Get testnet USDC: https://app.hyperliquid-testnet.xyz/
# Run paper trader: python scripts/hyperliquid_testnet_trader.py --dry-run
#
# Example for Hyperliquid MAINNET (use with caution):
# ---------------------------------------------------
# EXCHANGE_NAME=hyperliquid
# EXCHANGE_WALLET_PRIVATE_KEY=0x...your_mainnet_private_key
# EXCHANGE_WALLET_ADDRESS=0x...your_mainnet_address

# =============================================================================
# Multi-Wallet Configuration (Risk Distribution)
# =============================================================================
# Spread funds across multiple wallets to reduce single-point-of-failure risk.
# Each wallet can have independent limits and allocation weights.
#
# Format:
#   HYPERLIQUID_WALLETS=wallet1,wallet2,wallet3
#   HYPERLIQUID_WALLET_{name}_KEY=0x...
#   HYPERLIQUID_WALLET_{name}_ADDRESS=0x... (optional, derived from key)
#   HYPERLIQUID_WALLET_{name}_WEIGHT=1.0 (allocation weight)
#   HYPERLIQUID_WALLET_{name}_MAX_EXPOSURE=0.8 (max 80% of balance)
#   HYPERLIQUID_WALLET_{name}_MAX_POSITIONS=10
#   HYPERLIQUID_WALLET_{name}_ENABLED=true
#   HYPERLIQUID_WALLET_{name}_TAGS=main,btc-only
#
# Example (3 wallets with different purposes):
# --------------------------------------------
# HYPERLIQUID_WALLETS=main,hedge,aggressive
#
# # Main wallet - conservative, all assets
# HYPERLIQUID_WALLET_main_KEY=0xabc123...
# HYPERLIQUID_WALLET_main_WEIGHT=2.0
# HYPERLIQUID_WALLET_main_MAX_EXPOSURE=0.5
# HYPERLIQUID_WALLET_main_MAX_POSITIONS=5
# HYPERLIQUID_WALLET_main_TAGS=conservative
#
# # Hedge wallet - for shorts only
# HYPERLIQUID_WALLET_hedge_KEY=0xdef456...
# HYPERLIQUID_WALLET_hedge_WEIGHT=1.0
# HYPERLIQUID_WALLET_hedge_MAX_EXPOSURE=0.3
# HYPERLIQUID_WALLET_hedge_TAGS=short-only
#
# # Aggressive wallet - higher risk
# HYPERLIQUID_WALLET_aggressive_KEY=0x789ghi...
# HYPERLIQUID_WALLET_aggressive_WEIGHT=0.5
# HYPERLIQUID_WALLET_aggressive_MAX_EXPOSURE=0.9
# HYPERLIQUID_WALLET_aggressive_MAX_POSITIONS=15
# HYPERLIQUID_WALLET_aggressive_TAGS=aggressive,btc,eth
#
# Allocation Strategies (set in code):
# - round_robin: Rotate through wallets
# - lowest_exposure: Use wallet with lowest current exposure
# - weighted: Probabilistic based on weight
# - highest_balance: Use wallet with most available funds
# - specific: Caller specifies which wallet

# =============================================================================
# Multi-Wallet Paper Trading (Medallion V2)
# =============================================================================
# Paper trading runs on MAINNET with DRY RUN mode (real prices, no real orders).
# Balance is fetched from the API. If wallet has $0, fallback balance is used.
#
# Run: python scripts/hyperliquid_multi_wallet_paper.py
#
# Configuration:
#   HYPERLIQUID_WALLET_{name}_BALANCE=10000  # Fallback if API balance is $0
#   HYPERLIQUID_WALLET_{name}_LEVERAGE=5.0   # Base leverage for this wallet
#
# Example (3 wallets with different balances):
# --------------------------------------------
# HYPERLIQUID_WALLETS=small,medium,large
#
# HYPERLIQUID_WALLET_small_KEY=0xabc123...
# HYPERLIQUID_WALLET_small_BALANCE=10000
# HYPERLIQUID_WALLET_small_LEVERAGE=5.0
#
# HYPERLIQUID_WALLET_medium_KEY=0xdef456...
# HYPERLIQUID_WALLET_medium_BALANCE=50000
# HYPERLIQUID_WALLET_medium_LEVERAGE=5.0
#
# HYPERLIQUID_WALLET_large_KEY=0x789ghi...
# HYPERLIQUID_WALLET_large_BALANCE=100000
# HYPERLIQUID_WALLET_large_LEVERAGE=3.0

# Database
DATABASE_PATH=data/alphastrike.db

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Trading Mode
TRADING_ENABLED=true
PAPER_TRADING=false

# Risk Overrides (optional - defaults in config.py)
# MAX_LEVERAGE=20
# DAILY_DRAWDOWN_LIMIT=0.05
# TOTAL_DRAWDOWN_LIMIT=0.15
# MIN_BALANCE_THRESHOLD=9000.0

# =============================================================================
# Cloud Backup Configuration (Disaster Recovery)
# =============================================================================
# LIVE MODE ONLY - Cloud backup is automatically disabled in dry_run mode.
# Trades and positions are backed up asynchronously (non-blocking).
#
# Multi-tier backup for resilience:
# - Hot tier (Upstash Redis): 1-5ms latency, locks, current state
# - Warm tier (Turso SQLite): 5-10ms latency, recent events
# - Cold tier (Supabase): 50-100ms latency, full audit trail
#
# Leave empty to disable cloud backup (local logging only).

# Upstash Redis (Hot Tier) - https://upstash.com
# Free tier: 10K commands/day
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Turso SQLite (Warm Tier) - https://turso.tech
# Free tier: 9GB storage, 500M rows read/month
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Supabase (Cold Tier) - https://supabase.com
# Free tier: 500MB database, 1GB storage
SUPABASE_URL=
SUPABASE_KEY=

# Bot Instance ID (auto-generated if not set)
# Used for distributed locking to prevent split-brain
# INSTANCE_ID=alphastrike-prod-1
