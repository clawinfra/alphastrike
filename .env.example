# AlphaStrike Trading Bot - Environment Variables
# Copy this file to .env and fill in your values

# WEEX Exchange API Credentials
WEEX_API_KEY=your_api_key_here
WEEX_API_SECRET=your_api_secret_here
WEEX_API_PASSPHRASE=your_passphrase_here

# WEEX API Endpoints
WEEX_REST_URL=https://api.weex.com
WEEX_WS_URL=wss://ws.weex.com

# Database
DATABASE_PATH=data/alphastrike.db

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Trading Mode
TRADING_ENABLED=true
PAPER_TRADING=false

# Risk Overrides (optional - defaults in config.py)
# MAX_LEVERAGE=20
# DAILY_DRAWDOWN_LIMIT=0.05
# TOTAL_DRAWDOWN_LIMIT=0.15
# MIN_BALANCE_THRESHOLD=9000.0
